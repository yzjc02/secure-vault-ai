APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod
POSTGRES_DB=securevault
POSTGRES_USER=securevault_user
POSTGRES_PASSWORD=change-me-generated-by-setup
JWT_SECRET=change-me-generated-by-setup
JWT_EXPIRATION=86400000
FILE_STORAGE_DIR=/app/data/uploads
MAX_FILE_SIZE=20971520
CHUNK_SIZE=1000
CHUNK_OVERLAP_SIZE=150
CHUNK_MIN_SIZE=100
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_TOP_K=5
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BATCH_SIZE=16
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDINGS_PATH=/api/embeddings
